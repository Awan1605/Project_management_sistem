# ============================================================
# Konfigurasi Environment - Arviga Project Manager
# ============================================================
# Salin file ini menjadi .env dan isi nilai yang sesuai.
# JANGAN commit file .env ke repository!
# ============================================================

# ============================================================
# MODE DEBUG & KEAMANAN DASAR
# ============================================================

# Set 'False' untuk production, 'True' untuk development
DEBUG=True

# Secret key untuk signing session, CSRF, dll.
# Generate secret key baru untuk production: https://djecrety.ir/
# Minimal 50 karakter, jangan gunakan default di production!
SECRET_KEY=django-insecure-change-me-in-production-generate-new-key

# ============================================================
# KONFIGURASI HOST & DOMAIN
# ============================================================

# Daftar domain/IP yang boleh mengakses aplikasi (pisahkan dengan koma)
# Contoh development: localhost,127.0.0.1
# Contoh production: example.com,www.example.com,api.example.com
ALLOWED_HOSTS=localhost,127.0.0.1,task.arviga.co.id,www.task.arviga.co.id

# Domain yang diizinkan untuk CSRF (penting untuk AJAX & form submission)
# Contoh: https://example.com,https://www.example.com
CSRF_TRUSTED_ORIGINS=https://task.arviga.co.id,https://www.task.arviga.co.id,http://localhost:8000

# ============================================================
# KONFIGURASI DATABASE
# ============================================================

# Engine database (default: MySQL)
DB_ENGINE=django.db.backends.mysql

# Nama database
DB_NAME=arviga_db

# Username database
DB_USER=root

# Password database
DB_PASSWORD=your_database_password

# Host database (default: localhost)
DB_HOST=127.0.0.1

# Port database (MySQL default: 3306)
DB_PORT=3306

# ============================================================
# KONFIGURASI EMAIL SMTP
# ============================================================

# SMTP server host
EMAIL_HOST=smtp.gmail.com

# SMTP username (email pengirim)
EMAIL_HOST_USER=your-email@example.com

# SMTP password atau app-specific password
EMAIL_HOST_PASSWORD=your-email-password

# SMTP port (587 untuk TLS, 465 untuk SSL)
EMAIL_PORT=587

# Gunakan TLS? (True/False)
EMAIL_USE_TLS=True

# ============================================================
# KONFIGURASI GOOGLE OAUTH (allauth)
# ============================================================

# Google OAuth Client ID dari Google Cloud Console
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Google OAuth Client Secret
GOOGLE_OAUTH_SECRET=your-google-client-secret

# ============================================================
# KONFIGURASI AI SERVICES
# ============================================================

# Google Gemini API Key (dapatkan dari Google AI Studio)
GEMINI_API_KEY=your-gemini-api-key

# ============================================================
# KONFIGURASI OPSIONAL (Production)
# ============================================================

# Uncomment dan isi untuk production:

# HTTPS Security (wajib diaktifkan di production)
# SECURE_SSL_REDIRECT=True
# SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https

# Cookie Security (wajib diaktifkan di production dengan HTTPS)
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

# HSTS (HTTP Strict Transport Security)
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True
